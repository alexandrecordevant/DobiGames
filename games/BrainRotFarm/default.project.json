{
    "name": "Brain Rot Farm",
    "tree": {
        "$className": "DataModel",
        "ServerStorage": {
            "$className": "ServerStorage",
            "Modules": { "$path": "src/ServerStorage/Modules" }
        },
        "ReplicatedStorage": {
            "$className": "ReplicatedStorage",
            "SharedLib": {
                "$className": "Folder",
                "Shared": {
                    "$className": "Folder",
                    "UITheme": { "$path": "../shared-lib/src/shared/UITheme.lua" }
                }
            },
            "Modules": { "$path": "src/ReplicatedStorage/Modules" },
            "GameConfig": { "$path": "src/ReplicatedStorage/GameConfig.lua" }
        },
        "ServerScriptService": {
            "$className": "ServerScriptService",
            "$path": "src/ServerScriptService",
            "SharedLib": {
                "$className": "Folder",
                "Server": { "$path": "../shared-lib/src/server" },
                "Shared": {
                    "$className": "Folder",
                    "CollectSystem":  { "$path": "../shared-lib/src/shared/CollectSystem.lua" },
                    "UpgradeSystem":  { "$path": "../shared-lib/src/shared/UpgradeSystem.lua" }
                },
                "BRFilterSystem": { "$path": "../shared-lib/src/BRFilterSystem" }
            }
        },
        "StarterPlayer": {
            "$className": "StarterPlayer",
            "StarterPlayerScripts": {
                "$className": "StarterPlayerScripts",
                "Shared": { "$path": "../shared-lib/src/client" },
                "FlowerPotHUD": { "$path": "src/StarterPlayer/StarterPlayerScripts/FlowerPotHUD.client.lua" },
                "ShopHUD": { "$path": "src/StarterPlayer/StarterPlayerScripts/ShopHUD.client.lua" },
                "SlotMenuHUD": { "$path": "src/StarterPlayer/StarterPlayerScripts/SlotMenuHUD.client.lua" }
            }
        }
    }
}
